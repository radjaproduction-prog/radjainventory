    const hasPinj=document.getElementById('slipPinjamanRow').style.display!=='none',rows=document.getElementById('slipTbody').innerHTML;\
    const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Slip - $\{nama\}</title><link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet"><style>body\{font-family:'Outfit',sans-serif;background:#fff;color:#1A1005;padding:20px;max-width:400px;margin:0 auto\}.hd\{display:flex;justify-content:space-between;margin-bottom:8px\}.co\{font-size:10px;color:#A0907E;font-weight:700;text-transform:uppercase;letter-spacing:.1em\}.nm\{font-size:34px;font-weight:900;line-height:1;letter-spacing:-.02em\}.bg\{text-align:right;font-size:10px;font-weight:700;color:#E8641A\}.pr\{font-size:10px;color:#A0907E;margin-bottom:12px;text-transform:uppercase;font-weight:600\}table\{width:100%;border-collapse:collapse;margin-bottom:10px\}thead tr\{background:#FDE8DA\}th\{padding:7px 4px;font-size:9px;font-weight:800;text-align:center;color:#E8641A;letter-spacing:.06em\}td\{padding:8px 4px;border-bottom:1px solid #F2E4D6;text-align:center;font-size:10px\}.ln\{display:flex;justify-content:space-between;padding:6px 0;font-size:11px;font-weight:600;color:#A0907E\}.pt\{color:#D93025\}.tot\{color:#E8641A;font-size:17px;font-weight:800;border-top:2px solid #E8641A;margin-top:6px;padding-top:10px\}.prn\{margin-top:20px;text-align:center\}.prn button\{background:#E8641A;border:none;border-radius:12px;padding:12px 30px;font-size:14px;font-weight:700;cursor:pointer;color:#fff\}@media print\{.prn\{display:none\}@page\{size:A6 landscape;margin:6mm\}\}</style></head><body><div class="hd"><div><div class="co">Radja Production</div><div class="nm">$\{nama\}</div></div><div class="bg">$\{bagian\}</div></div><div class="pr">$\{periode\}</div><table><thead><tr><th>MODEL</th><th>SUB-BAGIAN</th><th>QTY</th><th>HARGA</th><th>JUMLAH</th></tr></thead><tbody>$\{rows\}</tbody></table><div class="ln"><span>Subtotal</span><span>$\{subtot\}</span></div>$\{hasPinj?`<div class="ln pt"><span>Bayar Pinjaman</span><span>- $\{pinj\}</span></div>`:''\}<div class="ln tot"><span>Total Bersih</span><span>$\{total\}</span></div><div class="prn"><button onclick="window.print()">
\f3 \uc0\u55357 \u56744 
\f0  Cetak / Simpan PDF</button></div></body></html>`;\
    const blob=new Blob([html],\{type:'text/html'\}),url=URL.createObjectURL(blob);window.open(url,'_blank');setTimeout(()=>URL.revokeObjectURL(url),30000);\
\}\
