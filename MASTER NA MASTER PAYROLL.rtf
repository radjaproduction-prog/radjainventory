\f0  Gagal memuat');\}finally\{hideLoading();\}\
\}\
function renderTabelPrint(filter='')\{\
    const tbody=document.getElementById('tbodyPrint');\
    const rows=filter?printRows.filter(r=>r.nama.toLowerCase().includes(filter.toLowerCase())):printRows;\
    if(!rows.length)\{tbody.innerHTML='<tr><td colspan="5" style="color:var(--muted);padding:20px;text-align:center;font-size:13px">Belum ada data</td></tr>';return;\}\
    tbody.innerHTML=rows.map(r=>`<tr>\
      <td><input type="checkbox" class="row-check" data-nama="$\{r.nama\}"></td>\
      <td style="font-weight:700;text-align:left;padding-left:12px">$\{r.nama\}</td>\
      <td style="color:var(--red)">$\{r.potongan>0?fmt(r.potongan):'-'\}</td>\
      <td><span class="kotor-label">Kotor: $\{fmt(r.total)\}</span><span class="bersih-val">$\{fmt(r.bersih)\}</span></td>\
      <td><button class="print-icon-btn" onclick="bukaSlipGaji('$\{r.nama.replace(/'/g,"\\\\'")\}')"><i class="fa-solid fa-print"></i></button></td>\
    </tr>`).join('');\
\}\
window.filterPrint=q=>renderTabelPrint(q);\
window.toggleCheckAll=cb=>document.querySelectorAll('.row-check').forEach(el=>el.checked=cb.checked);\
