async function getInputData(dari,sampai)\{\
    const c=[];if(dari)c.push(where('tanggalISO','>=',dari));if(sampai)c.push(where('tanggalISO','<=',sampai));\
    const snap=await getDocs(query(collection(db,COL.input),...c));return snap.docs.map(d=>(\{id:d.id,...d.data()\}));\
\}\
async function getRekapPinjaman()\{\
    const [pinSnap,bayarSnap]=await Promise.all([getDocs(collection(db,COL.pinjaman)),getDocs(collection(db,COL.bayar))]);\
    const pP=\{\},bP=\{\},jP=\{\};\
    pinSnap.forEach(d=>\{const v=d.data();pP[v.nama]=(pP[v.nama]||0)+(v.nominal||0);if(!jP[v.nama])jP[v.nama]=new Set();if(v.jenis)jP[v.nama].add(v.jenis);\});\
    bayarSnap.forEach(d=>\{const v=d.data();bP[v.nama]=(bP[v.nama]||0)+(v.bayar||0);\});\
    const allNama=new Set([...Object.keys(pP),...Object.keys(bP)]);const res=[];\
    allNama.forEach(nama=>\{const pinjaman=pP[nama]||0,bayar=bP[nama]||0,jenis=jP[nama]?[...jP[nama]].join(', '):'-';res.push(\{nama,jenis,pinjaman,bayar,sisa:pinjaman-bayar\});\});\
    return res;\
\}\
async function getRincian(nama,dari,sampai)\{\
    const semua=await getInputData(dari,sampai),items=semua.filter(r=>r.nama===nama);\
    let subtotal=0;const rows=items.map(r=>\{subtotal+=(r.jumlah||0);return\{model:r.model,jenis:r.jenis,qty:r.qty,harga:r.harga,jumlah:r.jumlah\};\});\
    const pinData=await getRekapPinjaman(),pinRow=pinData.find(r=>r.nama===nama);\
    const potongan=pinRow?Math.max(0,pinRow.sisa):0,bagian=items.length>0?(items[0].bagian||'-'):'-';\
    return\{items:rows,subtotal,potongan,total:subtotal-potongan,bagian\};\
\}\
