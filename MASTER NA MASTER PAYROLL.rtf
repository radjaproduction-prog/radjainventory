    .slip-table thead tr \{ background:var(--orange3); \}\
    .slip-table th \{ padding:7px 4px; font-size:9px; font-weight:800; text-align:center; letter-spacing:.06em; color:var(--orange); \}\
    .slip-table td \{ padding:8px 4px; border-bottom:1px solid var(--bg2); text-align:center; font-size:10px; color:var(--text); \}\
    .slip-line \{ display:flex; justify-content:space-between; align-items:center; padding:6px 0; font-size:11px; font-weight:600; color:var(--muted); \}\
    .slip-line.potongan \{ color:var(--red); \}\
