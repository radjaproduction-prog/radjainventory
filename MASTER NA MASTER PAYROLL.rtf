window.bukaSlipGaji=async nama=>\{\
    const dari=_getISO('printMulai'),sampai=_getISO('printAkhir');showLoading('Memuat slip...');\
    try\{\
        const data=await getRincian(nama,dari,sampai);if(!data.items.length)\{showToast('
\f2 \uc0\u9888 
\f0  Tidak ada data!');return;\}\
        document.getElementById('slipNama').textContent=nama;document.getElementById('slipBagian').textContent=data.bagian||'-';\
        document.getElementById('slipPeriode').textContent='Periode: '+(_tgl.printMulai||'--')+' \'97 '+(_tgl.printAkhir||'--');\
        document.getElementById('slipTbody').innerHTML=data.items.map(r=>`<tr><td>$\{r.model||'-'\}</td><td>$\{r.jenis||'-'\}</td><td>$\{r.qty||0\}</td><td>$\{fmt(r.harga)\}</td><td>$\{fmt(r.jumlah)\}</td></tr>`).join('');\
        document.getElementById('slipSubtotal').textContent=fmt(data.subtotal||0);\
        document.getElementById('slipPinjaman').textContent=fmt(data.potongan||0);\
        document.getElementById('slipPinjamanRow').style.display=data.potongan>0?'flex':'none';\
        document.getElementById('slipTotal').textContent=fmt(data.total||0);\
        document.getElementById('slipPopup').classList.add('active');\
    \}catch(e)\{showToast('
\f3 \uc0\u10060 
\f0  Gagal: '+e.message);\}finally\{hideLoading();\}\
\};\
window.tutupSlip=()=>document.getElementById('slipPopup').classList.remove('active');\
window.cetakSlip=()=>\{if(typeof window.print==='function')\{try\{window.print();return;\}catch(e)\{\}\}_bukaSlipDiTabBaru();\};\
function _bukaSlipDiTabBaru()\{\
    const nama=document.getElementById('slipNama').textContent,bagian=document.getElementById('slipBagian').textContent;\
    const periode=document.getElementById('slipPeriode').textContent,subtot=document.getElementById('slipSubtotal').textContent;\
