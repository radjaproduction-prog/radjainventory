window.bukaDatePicker=target=>\{\
    dpTarget=target;const titles=\{mulai:'Tanggal Mulai',akhir:'Tanggal Akhir',printMulai:'Tanggal Mulai',printAkhir:'Tanggal Akhir'\};\
    document.getElementById('dpTitle').textContent=titles[target]||'Pilih Tanggal';\
    const stateMap=\{mulai:'rekapMulai',akhir:'rekapAkhir',printMulai:'printMulai',printAkhir:'printAkhir'\};\
    const label=_tgl[stateMap[target]]||'';\
    if(label&&label.includes('/'))\{const p=label.split('/');document.getElementById('dpInput').value=`$\{p[2]\}-$\{p[1].padStart(2,'0')\}-$\{p[0].padStart(2,'0')\}`;\}\
    else document.getElementById('dpInput').value='';\
    document.getElementById('datePickerPopup').classList.add('active');\
\};\
window.tutupDatePicker=()=>document.getElementById('datePickerPopup').classList.remove('active');\
window.konfirmasiDatePicker=async()=>\{\
