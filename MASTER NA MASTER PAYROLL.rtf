<script type="module">\
'use strict';\
import \{ initializeApp \} from "https://www.gstatic.com/firebasejs/10.11.1/firebase-app.js";\
import \{\
    getFirestore, collection, addDoc, deleteDoc, doc,\
    getDocs, query, where, serverTimestamp, onSnapshot, updateDoc\
\} from "https://www.gstatic.com/firebasejs/10.11.1/firebase-firestore.js";\
\
const firebaseConfig = \{\
    apiKey: "AIzaSyCmXq626LVNe4EY7PGbPYcOlvki_JbM3vg",\
    authDomain: "inventory-raja-production.firebaseapp.com",\
    projectId: "inventory-raja-production",\
    storageBucket: "inventory-raja-production.firebasestorage.app",\
    messagingSenderId: "798451981499",\
    appId: "1:798451981499:web:08cf90ef66f89073651d9e"\
\};\
const app = initializeApp(firebaseConfig);\
const db  = getFirestore(app);\
const COL = \{ master:'payroll_master', harga:'payroll_harga', input:'payroll_input', pinjaman:'payroll_pinjaman', bayar:'payroll_bayar' \};\
\
let MASTER = \{ pegawai:[], bagian:[], subBagian:\{\}, model:[], harga:\{\}, jenisPinjaman:[] \};\
let _masterDocIds=\{\}, _hargaDocIds=\{\};\
let rekapRows=[], rekapPinRows=[], printRows=[];\
let currentTab='pegawai', listType='', dpTarget='';\
let _sisaPerNama=\{\}, _nilaiPerNama=\{\};\
let _tgl=\{ rekapMulai:'', rekapAkhir:'', printMulai:'', printAkhir:'' \};\
\
const showLoading=t=>\{document.getElementById('loadingText').textContent=t||'Memuat...';document.getElementById('loadingOverlay').classList.add('active');\};\
const hideLoading=()=>document.getElementById('loadingOverlay').classList.remove('active');\
function showToast(msg,dur=3000)\{const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),dur);\}\
window.tutupPopup=id=>document.getElementById(id).style.display='none';\
const bukaPopup=id=>document.getElementById(id).style.display='flex';\
const fmt=n=>Number(n||0).toLocaleString('id-ID');\
function resetSelect(id,items,ph,dis=false)\{const el=document.getElementById(id);el.innerHTML=`<option value="">$\{ph\}</option>`;(items||[]).forEach(v=>el.innerHTML+=`<option value="$\{v\}">$\{v\}</option>`);el.value='';el.disabled=dis;\}\
const setDis=(id,v)=>\{const el=document.getElementById(id);if(el)el.disabled=v;\};\
const fmtTgl=d=>`$\{String(d.getDate()).padStart(2,'0')\}/$\{String(d.getMonth()+1).padStart(2,'0')\}/$\{d.getFullYear()\}`;\
const tglHariIni=()=>fmtTgl(new Date());\
function _getISO(key)\{const v=_tgl[key]||'';if(!v||!v.includes('/'))return'';const p=v.split('/');return`$\{p[2]\}-$\{p[1].padStart(2,'0')\}-$\{p[0].padStart(2,'0')\}`;\}\
function _setTgl(key,label)\{_tgl[key]=label;const map=\{rekapMulai:'tglMulaiTxt',rekapAkhir:'tglAkhirTxt',printMulai:'printTglMulaiTxt',printAkhir:'printTglAkhirTxt'\};const el=document.getElementById(map[key]);if(el)el.textContent=label||'--/--/----';\}\
\
function initMasterListener()\{\
    onSnapshot(collection(db,COL.master),snap=>\{\
        const m=\{pegawai:[],bagian:[],subBagian:\{\},model:[],jenisPinjaman:[]\};\
        _masterDocIds=\{\};\
        snap.forEach(d=>\{\
            const data=d.data();_masterDocIds[data.type+'|'+data.nama]=d.id;\
            if(data.type==='pegawai') m.pegawai.push(data.nama);\
            if(data.type==='bagian')  m.bagian.push(data.nama);\
            if(data.type==='model')   m.model.push(data.nama);\
            if(data.type==='jenisPinjaman') m.jenisPinjaman.push(data.nama);\
            if(data.type==='subbagian')\{if(!m.subBagian[data.bagianInduk])m.subBagian[data.bagianInduk]=[];m.subBagian[data.bagianInduk].push(data.nama);\}\
        \});\
        MASTER.pegawai=m.pegawai.sort();MASTER.bagian=m.bagian.sort();MASTER.subBagian=m.subBagian;MASTER.model=m.model.sort();MASTER.jenisPinjaman=m.jenisPinjaman.sort();\
    \});\
    onSnapshot(collection(db,COL.harga),snap=>\{\
        _hargaDocIds=\{\};MASTER.harga=\{\};\
        snap.forEach(d=>\{const data=d.data();const key=data.jenis+'-'+data.model;MASTER.harga[key]=data.harga;_hargaDocIds[key]=d.id;\});\
    \});\
\}\
\
window.bukaInputData=async()=>\{\
    resetSelect('inp_nama',MASTER.pegawai,'-- Pilih Pegawai --');\
    resetSelect('inp_bagian',MASTER.bagian,'-- Pilih Bagian --',true);\
    resetSelect('inp_jenis',[],'-- Pilih Sub-Bagian --',true);\
    resetSelect('inp_model',MASTER.model,'-- Pilih Model --',true);\
    setDis('inp_qty',true);['inp_qty','inp_harga_display','inp_total_display'].forEach(id=>document.getElementById(id).value='');\
    setDis('btnSimpanInput',true);bukaPopup('inputPopup');\
