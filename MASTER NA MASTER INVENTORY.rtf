function simpanInputData() \{\
  var tipe    = document.getElementById("input-tipe").value;\
  var brand   = document.getElementById("input-brand").value;\
  var model   = document.getElementById("input-model").value;\
  var warna   = document.getElementById("input-warna").value;\
  var ukuran  = document.getElementById("input-ukuran").value;\
  var qty     = document.getElementById("input-qty").value;\
\
  if (!brand || !model || !warna || !ukuran || !qty || qty <= 0) \{\
    tampilkanPopup("Data belum lengkap!");\
    return;\
  \}\
  \
  tampilkanLoading("SEDANG MENYIMPAN...");\
\
  if (tipe === "keluar") \{\
    simpanReturKeFirebase(brand, model, warna, ukuran, parseInt(qty))\
    .then(function() \{\
      document.getElementById('input-ukuran').value = '';\
      document.getElementById('input-qty').value = '';\
      sembunyikanLoading();\
      tampilkanPopup("Stok Cacat Berhasil Dikeluarkan & Dicatat di Riwayat!");\
    \}).catch(function(err) \{\
      sembunyikanLoading();\
      tampilkanPopup("Error: " + err.message);\
    \});\
  \} else \{\
    simpanKeFirebase(\{\
      brand: brand,\
      model: model,\
      warna: warna,\
      ukuran: ukuran,\
      jumlah: parseInt(qty),\
      keterangan: "Input Stok"\
    \}).then(function() \{\
      document.getElementById('input-ukuran').value = '';\
      document.getElementById('input-qty').value = '';\
      sembunyikanLoading();\
      tampilkanPopup("Stok Baru Tersimpan!");\
    \}).catch(function(err) \{\
      sembunyikanLoading();\
      tampilkanPopup("Error: " + err.message);\
    \});\
  \}\
\}\
