//  Isi URL deploy Payroll kamu di sini\
const PAYROLL_URL = "https://script.google.com/macros/s/AKfycby0C1y6d8m3GIsyCIGXN2-a6nfgTwZ_kqy6Zs2MH7VrnN3_SH_vIPuTFir0YkopKOvElg/exec";\
function bukaAppPayroll() \{\
  if (!PAYROLL_URL || PAYROLL_URL === "GANTI_DENGAN_URL_PAYROLL_KAMU") \{\
    tampilkanPopup("URL Aplikasi Payroll belum dikonfigurasi.\\nSilakan isi PAYROLL_URL di kode.");\
return;\
  \}\
  window.open(PAYROLL_URL, '_blank');\
\}\
\
(function() \{\
var format = new Date().toLocaleDateString('id-ID', \{ weekday:'long', year:'numeric', month:'long', day:'numeric' \});\
document.querySelectorAll('.tgl-txt').forEach(function(el) \{ el.innerText = format; \});\
\})();\
function formatTgl(val) \{\
if (!val) return '';\
if (val && typeof val.toDate === 'function') val = val.toDate();\
if (val instanceof Date && !isNaN(val)) \{\
return val.getDate().toString().padStart(2,'0') + '/' +\
(val.getMonth()+1).toString().padStart(2,'0') + '/' +\
val.getFullYear();\
\}\
return String(val);\
\}\
\
function formatRp(angka) \{ return 'Rp ' + (parseInt(angka)||0).toLocaleString('id-ID'); \}\
\
function customSortUkuran(a, b) \{\
  var urutan = ['S', 'M', 'L', 'XL', '2XL', '3XL', 'AL'];\
  var idxA = urutan.indexOf(String(a).toUpperCase().trim());\
  var idxB = urutan.indexOf(String(b).toUpperCase().trim());\
  \
  // Jika ukurannya tidak ada di daftar baku, taruh di paling bawah\
  if (idxA === -1) idxA = 999;\
  if (idxB === -1) idxB = 999;\
  \
  if (idxA !== idxB) return idxA - idxB;\
  return String(a).localeCompare(String(b));\
\}\
\
function tampilkanLoading(txt) \{\
var el = document.getElementById('loading-overlay');\
var txtEl = document.getElementById('loading-text-msg');\
if (txtEl) txtEl.innerText = txt || 'Data synchronization';\
el.style.display = 'flex';\
\}\
\
function sembunyikanLoading() \{ document.getElementById('loading-overlay').style.display = 'none';\
\}\
\
function tampilkanPopup(pesan) \{\
document.getElementById("popup-message").innerText = pesan;\
document.getElementById("custom-popup").style.display = "flex";\
\}\
\
function tutupPopup() \{ document.getElementById("custom-popup").style.display = "none"; \}\
\
