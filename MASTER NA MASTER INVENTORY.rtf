if (currentRole==='admin') \{\
nav.innerHTML =\
'<div class="nav-btn inactive" data-tab="1" onclick="showTab(1,this)"><svg viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg><span>Home</span></div>'+\
