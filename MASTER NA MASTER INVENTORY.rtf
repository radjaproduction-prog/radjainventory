function filterHome() \{\
var brand = document.getElementById("home-filter-brand").value;\
var tbody = document.getElementById("home-table-body");\
var title = document.getElementById("home-title");\
tbody.innerHTML = "";\
if (!brand) \{ clearHome(); return; \}\
title.innerText = brand;\
var wm = document.getElementById('home-watermark'); if(wm) wm.style.display='none';\
var filtered = dataHomeGlobal.filter(function(r) \{ return r[0]===brand; \});\
if (homeSortCol) \{\
var _so = ['S','M','L','XL','XXL','2XL','3XL','ALS'];\
filtered = filtered.slice().sort(function(a,b) \{\
if (homeSortCol==='model') \{ var ai=String(a[1]||''),bi=String(b[1]||''); return homeSortAsc?ai.localeCompare(bi):bi.localeCompare(ai); \}\
if (homeSortCol==='warna') \{ var ai=String(a[2]||''),bi=String(b[2]||''); return homeSortAsc?ai.localeCompare(bi):bi.localeCompare(ai); \}\
if (homeSortCol==='ukuran') \{ var ai=_so.indexOf(String(a[3]||'').toUpperCase()),bi=_so.indexOf(String(b[3]||'').toUpperCase()); if(ai===-1)ai=999; if(bi===-1)bi=999; return homeSortAsc?ai-bi:bi-ai; \}\
return 0;\
\});\
\}\
var total = 0;\
if (filtered.length===0) \{\
tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-dim);padding:20px 0;">Tidak ada stok</td></tr>';\
\} else \{\
filtered.forEach(function(r) \{\
var tr = document.createElement("tr");\
tr.innerHTML = '<td class="txt-model">'+(r[1]||'')+'</td><td>'+(r[2]||'')+'</td><td class="txt-ukuran">'+(r[3]||'')+'</td><td class="txt-qty">'+(r[4]||0)+'</td>';\
tbody.appendChild(tr);\
total += parseInt(r[4]||0);\
\});\
\}\
document.getElementById("total-qty-val").innerText = total;\
\}\
