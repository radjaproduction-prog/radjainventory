document.getElementById('pin-error-txt').innerText = "";\
updatePinDots();\
\}\
\
function sembunyikanPinPad() \{\
pinTargetRole = "";\
currentPinInput = "";\
document.getElementById('pin-pad-container').style.display = 'none';\
document.getElementById('welcome-menu-list').style.display = 'flex';\
\}\
\
function inputDigit(digit) \{\
if (currentPinInput.length < 6) \{\
currentPinInput += digit;\
updatePinDots();\
document.getElementById('pin-error-txt').innerText = "";\
if (currentPinInput.length === 6) setTimeout(validasiPin, 150);\
\}\
\}\
\
function hapusDigit() \{\
if (currentPinInput.length > 0) \{\
currentPinInput = currentPinInput.slice(0,-1);\
updatePinDots();\
document.getElementById('pin-error-txt').innerText = "";\
\}\
\}\
\
function updatePinDots() \{\
document.querySelectorAll('#pin-dots-wrapper .pin-bar').forEach(function(dot,i) \{\
dot.classList.toggle('filled', i < currentPinInput.length);\
\});\
\}\
\
function validasiPin() \{\
var benar = false;\
if (pinTargetRole==='owner' && currentPinInput===PIN_OWNER) \{ currentRole="owner";\
benar=true; \}\
else if (pinTargetRole==='penggajihan' && currentPinInput===PIN_PENGGAJIHAN) \{ currentRole="penggajihan"; benar=true; \}\
if (benar) \{ sembunyikanPinPad(); masukSistem(); \}\
else \{ document.getElementById('pin-error-txt').innerText="PIN SALAH!"; currentPinInput=""; updatePinDots();\
\}\
\}\
\
function aksesHalaman(role) \{\
if (role==='admin') \{ currentRole="admin"; masukSistem(); \}\
\}\
