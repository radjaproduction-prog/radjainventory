function updateHargaAwalDisplay() \{\
  var brand = document.getElementById("edit-brand").value;\
  var model = document.getElementById("edit-model").value;\
  var inputHarga = document.getElementById("edit-harga");\
  var inputAwal = document.getElementById("edit-harga-awal");\
  var btnSimpan = document.getElementById("btn-simpan-harga");\
  var btnEdit = document.getElementById("btn-edit-harga");\
  var labelBaru = document.getElementById("label-harga-baru");\
\
  inputHarga.value = "";\
  inputHarga.disabled = true;\
  inputHarga.style.opacity = "1"; // Tetap terang\
  inputHarga.style.cursor = "not-allowed";\
\
  btnSimpan.style.opacity = "0.4";\
  btnSimpan.style.pointerEvents = "none";\
\
  if (!brand || !model) \{\
    inputAwal.value = "";\
    inputAwal.placeholder = "Pilih brand & model dulu...";\
    inputAwal.style.color = "var(--text-dim)";\
    inputAwal.style.fontWeight = "400"; // Paksa jadi tipis\
    btnEdit.style.display = "none";\
    labelBaru.innerText = "HARGA BARU (per pcs)";\
    return;\
