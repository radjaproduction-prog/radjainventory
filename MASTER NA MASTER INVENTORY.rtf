async function editQtyTransaksiFirebase(idTrx, newQty) \{\
  const q = query(collection(db,"transaksi"), where("idTrx","==",idTrx));\
  const snap = await getDocs(q);\
  let trxRef, trxData;\
  if (!snap.empty) \{ trxRef = snap.docs[0].ref; trxData = snap.docs[0].data(); \}\
  else \{ const s2 = await getDocs(collection(db,"transaksi")); const f=s2.docs.find(d=>d.id===idTrx); if(!f) throw new Error("Tidak ditemukan"); trxRef=f.ref; trxData=f.data(); \}\
  const oldQty = parseInt(trxData.qty)||0, diff = newQty - oldQty;\
  const sq = query(collection(db,"stok"), where("brand","==",trxData.brand), where("model","==",trxData.model), where("warna","==",trxData.warna), where("ukuran","==",trxData.ukuran));\
  const ss = await getDocs(sq);\
  await runTransaction(db, async (t) => \{\
    let curStokQty = 0;\
    if (!ss.empty) \{\
      const stokSnap = await t.get(ss.docs[0].ref);\
      curStokQty = parseInt(stokSnap.data().qty) || 0;\
      if (curStokQty - diff < 0) throw new Error("Stok tidak mencukupi (" + curStokQty + " pcs tersisa)");\
    \}\
    t.update(trxRef, \{ qty: newQty, hargaTotal: (parseInt(trxData.hargaSatuan)||0)*newQty \});\
    if (!ss.empty) \{\
      t.update(ss.docs[0].ref, \{ qty: curStokQty - diff \});\
    \}\
  \});\
  return \{ success: true, message: "QTY berhasil diperbarui menjadi " + newQty + " pcs!" \};\
\}\
\
// === Simpan Harga ===\
async function simpanHargaKeFirebase(brand, model, harga) \{\
  const q = query(collection(db,"harga"), where("brand","==",brand), where("model","==",model));\
  const snap = await getDocs(q);\
  if (!snap.empty) \{ await updateDoc(snap.docs[0].ref, \{ harga, updatedAt: serverTimestamp() \}); \}\
  else \{ await addDoc(collection(db,"harga"), \{ brand, model, harga, createdAt: serverTimestamp() \}); \}\
  return \{ success: true, message: "Harga " + brand + " " + model + " berhasil disimpan!" \};\
\}\
\
// === Simpan Master ===\
async function simpanMasterKeFirebase(data) \{\
  const payload = \{ jenis: data.jenis, nama: data.nama, waktu: serverTimestamp() \};\
  if (data.wa) payload.wa = data.wa; // Masukkan No WA ke payload jika ada\
  return await addDoc(collection(db, "master_data"), payload);\
\}\
\
// === Hapus Master ===\
async function hapusMasterDariFirebase(jenis, nama) \{\
  const docId = masterDocIds[jenis + '|' + nama];\
  if (!docId) throw new Error('Data tidak ditemukan');\
  await deleteDoc(doc(db, "master_data", docId));\
\}\
\
// === Hapus Transaksi ===\
async function hapusTransaksiFirebase(docIds) \{\
  const batch = writeBatch(db);\
  for (const id of docIds) \{\
    batch.delete(doc(db, "transaksi", id));\
  \}\
  await batch.commit();\
  return \{ success: true, message: docIds.length + ' transaksi berhasil dihapus!' \};\
\}\
\
// Letakkan di bagian bawah bersama fungsi Firebase lainnya\
async function tandaiSudahDicetak(docIds) \{\
  const batch = writeBatch(db);\
  docIds.forEach(id => \{\
    batch.update(doc(db, "transaksi", id), \{ isPrinted: true \});\
  \});\
  await batch.commit();\
\}\
\
// --- KODE TAMBAHAN UNTUK OVERRIDE MAKSIMAL ---\
window.tambahMaster = function(jenis) \{\
  var inputId = 'new-' + jenis;\
  var val = (document.getElementById(inputId).value || '').trim().toUpperCase();\
  \
  if (!val) \{ \
    tampilkanPopup('Isi nama ' + jenis + ' terlebih dahulu!'); \
    return; \
  \}\
  \
  var dataMaster = \{ jenis: jenis, nama: val \};\
  \
  // Jika yang ditambah adalah VENDOR, wajib isi nomor WA juga\
  if (jenis === 'vendor') \{\
    var waInput = document.getElementById('new-vendor-wa');\
    var waVal = (waInput.value || '').trim();\
    if (!waVal) \{ \
      tampilkanPopup('Isi Nomor WhatsApp Vendor!'); \
      return; \
    \}\
    dataMaster.wa = waVal;\
  \}\
  \
  tampilkanLoading('MENYIMPAN KE FIREBASE...');\
  simpanMasterKeFirebase(dataMaster)\
  .then(function() \{\
    // Reset kedua kolom\
    document.getElementById(inputId).value = '';\
    if (jenis === 'vendor') \{\
      document.getElementById('new-vendor-wa').value = '';\
    \}\
    sembunyikanLoading();\
    tampilkanPopup(jenis.toUpperCase() + " berhasil ditambahkan!");\
  \}).catch(function(err) \{\
    sembunyikanLoading();\
    tampilkanPopup("Error: " + err);\
  \});\
\};\
\
// --- FUNGSI DOWNLOAD STRUK SEBAGAI GAMBAR ---\
window.downloadPreviewImage = function() \{\
  var iframe = document.getElementById('preview-iframe');\
  if (!iframe) return;\
  \
  tampilkanLoading("Mengunduh Dokumen...");\
  \
  // Proses Foto Struk dari dalam iframe\
  var targetNode = iframe.contentWindow.document.body;\
  html2canvas(targetNode, \{ scale: 2, useCORS: true \}).then(canvas => \{\
     var imgData = canvas.toDataURL("image/jpeg", 0.9);\
     var docTitle = document.getElementById('preview-judul').innerText || 'Dokumen';\
     \
     // Proses Download Otomatis\
     var link = document.createElement('a');\
     link.download = docTitle + ".jpg";\
     link.href = imgData;\
     link.click();\
     \
     sembunyikanLoading();\
     tampilkanPopup("Dokumen berhasil diunduh ke galeri/perangkat Anda!");\
     \
  \}).catch(err => \{\
     sembunyikanLoading();\
     alert("Gagal mengunduh gambar: " + err);\
  \});\
\};\
\
function toggleSelectAllCetak(cbAll) \{\
  // Jika ceklis master dilepas, lepas semua pilihan\
  if (!cbAll.checked) \{\
    clearCetakSelection();\
    return;\
  \}\
  \
  // Jika ada vendor yang terkunci (dari klik manual pertama)\
  if (cetakMergeLockVendor) \{\
    _cetakRenderedData.forEach(function(t, idx) \{\
      var vendor = String(t[2]||'');\
      // Hanya ceklis vendor yang sama persis\
      if (vendor === cetakMergeLockVendor) \{\
        var cb = document.getElementById('cetak-cb-' + idx);\
        // Pastikan bukan checkbox yang di-disable (karena harga 0)\
        if (cb && !cb.disabled) \{\
          cb.checked = true;\
          if (cetakMergeSelected.indexOf(idx) === -1) \{\
            cetakMergeSelected.push(idx);\
          \}\
        \}\
      \}\
    \});\
    // Perbarui status gembok baris dan tombol bawah\
    _updateCetakRowLock();\
    updateCetakBottomBar();\
  \} else \{\
    // Jaga-jaga jika terklik tapi tidak ada vendor terkunci\
    cbAll.checked = false; \
  \}\
\}\
