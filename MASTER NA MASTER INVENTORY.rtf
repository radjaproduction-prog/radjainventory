function onEditBrandChange() \{\
  var brand = document.getElementById("edit-brand").value;\
  var modelEl = document.getElementById("edit-model");\
  \
  if (!brand) \{\
    if (modelEl) \{\
      modelEl.required = true; // PENTING: Memaksa trik CSS agar aktif\
      modelEl.innerHTML = '<option value="" disabled selected hidden>PILIH MODEL...</option>';\
      modelEl.value = ""; // PENTING: Memaksa browser membaca ini kosong\
      modelEl.disabled = true;\
      modelEl.style.opacity = "1"; \
      modelEl.style.cursor = "not-allowed";\
    \}\
  \} else \{\
    isiDropdownDariStok("edit-model", "model", \{brand: brand\});\
    if (modelEl) \{\
      modelEl.value = "";\
      modelEl.disabled = false;\
      modelEl.style.opacity = "1"; \
      modelEl.style.cursor = "pointer";\
    \}\
  \}\
  \
  var hargaEl = document.getElementById("edit-harga");\
  if (hargaEl) \{\
