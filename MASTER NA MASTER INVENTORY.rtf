function cekTransaksiLengkap() \{\
var vendor=document.getElementById("trx-vendor").value;\
var brand=document.getElementById("trx-brand").value;\
var model=document.getElementById("trx-model").value;\
var warna=document.getElementById("trx-warna").value;\
var ukuran=document.getElementById("trx-ukuran").value;\
var qty=String(document.getElementById("trx-qty")?document.getElementById("trx-qty").value||"":"").trim();\
var qtyOk = qty && /^\\d+$/.test(qty) && parseInt(qty)>0;\
var allFilled = vendor && brand && model && warna && ukuran && qtyOk;\
if (allFilled) \{\
var found=dataHomeGlobal.find(function(r)\{return r[0]===brand&&r[1]===model&&r[2]===warna&&r[3]===ukuran;\});\
var sisa=found?parseInt(found[4]):0;\
if(parseInt(qty)>sisa) allFilled=false;\
\}\
var btn=document.getElementById("btn-simpan-trx");\
if(btn)\{btn.style.opacity=allFilled?"1":"0.35";\}\
\}\
