function simpanTransaksi() \{\
  var vendor=document.getElementById("trx-vendor").value,\
      brand=document.getElementById("trx-brand").value,\
      model=document.getElementById("trx-model").value,\
      warna=document.getElementById("trx-warna").value,\
      ukuran=document.getElementById("trx-ukuran").value,\
      qty=document.getElementById("trx-qty").value;\
\
  if (!vendor||!brand||!model||!warna||!ukuran||!qty||qty<=0) \{ \
      tampilkanPopup("Lengkapi semua data transaksi!"); return; \
  \}\
  \
  tampilkanLoading("MENYIMPAN TRANSAKSI...");\
  \
  simpanTransaksiKeFirebase(vendor, brand, model, warna, ukuran, parseInt(qty))\
  .then(function(res) \{\
    if (res&&res.success) \{\
      var _sv=document.getElementById("trx-vendor").value;\
      var _sb=document.getElementById("trx-brand").value;\
      var _sm=document.getElementById("trx-model").value;\
      var _sw=document.getElementById("trx-warna").value;\
\
      document.getElementById("trx-ukuran").value="";\
      document.getElementById("trx-qty").value="";\
      var qtyEl=document.getElementById("trx-qty"); if(qtyEl) qtyEl.classList.remove("qty-over","qty-ok");\
      var warnEl=document.getElementById("trx-qty-warn"); if(warnEl)\{warnEl.innerText=""; warnEl.className="qty-warn";\}\
      document.getElementById("trx-sisa-stok").value="";\
\
      var ve=document.getElementById("trx-vendor"); if(ve) ve.value=_sv;\
      var be=document.getElementById("trx-brand"); if(be) be.value=_sb;\
      isiDropdownDariStok("trx-model","model",\{brand:_sb\});\
      var me=document.getElementById("trx-model"); if(me) me.value=_sm;\
      isiDropdownDariStok("trx-warna","warna",\{brand:_sb,model:_sm\});\
      var we=document.getElementById("trx-warna"); if(we) we.value=_sw;\
      isiDropdownDariStok("trx-ukuran","ukuran",\{brand:_sb,model:_sm,warna:_sw\});\
\
      cekTransaksiLengkap();\
\
      sembunyikanLoading();\
      tampilkanPopup(res.message||"Transaksi berhasil disimpan!");\
    \} else \{\
      sembunyikanLoading();\
      tampilkanPopup("Gagal: "+(res?res.message:"Terjadi kesalahan"));\
    \}\
  \}).catch(function(err)\{ \
      sembunyikanLoading(); \
      tampilkanPopup("Error: "+err.toString()); \
  \});\
