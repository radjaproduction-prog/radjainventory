function renderPelunasan(data) \{\
  var tbody = document.getElementById("pelunasan-tbody");\
  if (!tbody) return;\
  \
  var cbAll = document.getElementById("select-all-check");\
  if (cbAll) \{\
    cbAll.checked = false;\
    cbAll.disabled = true; \
  \}\
  \
  if (!data || data.length === 0) \{\
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-dim);">Tidak ada transaksi CREDIT</td></tr>';\
    return;\
  \}\
  \
  var html = '';\
  data.forEach(function(t) \{\
    var _hs = parseInt(t[9] || 0);\
    var _ht = parseInt(t[10] || 0);\
    var hargaSatuan = _hs > 0 ? _hs : (cariHargaAwal(String(t[3]||''), String(t[4]||'')) || 0);\
    var hargaTotal  = _ht > 0 ? _ht : (hargaSatuan * parseInt(t[7]||0));\
    var noHarga = hargaSatuan === 0;\
    \
    var st = noHarga \
      ? '<span style="background:#e0f2fe; color:#0284c7; padding:4px 8px; border-radius:20px; font-size:9px; font-weight:800; border:1px solid #bae6fd; display:inline-flex; align-items:center; letter-spacing:0.5px;">&#9888; HARGA KOSONG</span>' \
      : '<span class="status-credit">&#9679; CREDIT</span>';\
\
    // Perhatikan tambahan data-noharga="true" di bawah ini\
    html += '<tr data-vendor="' + String(t[2]||'') + '"' + (noHarga ? ' style="opacity:0.4;pointer-events:none;"' : '') + '>'+\
    '<td class="check-cell"><input type="checkbox" value="' + String(t[0]) + '" data-vendor="' + String(t[2]||'') + '"' + (noHarga ? ' disabled data-noharga="true"' : '') + ' onchange="onPelunasanCheckChange(this)"></td>'+\
    '<td><span class="txt-id">' + String(t[0]) + ' | ' + formatTgl(t[1]) + '</span><span class="txt-vendor">' + String(t[2]||'') + '</span></td>'+\
    '<td><span class="txt-pelunasan-brand">' + String(t[3]||'') + '</span><span class="txt-pelunasan-model">' + String(t[4]||'') + ' [' + String(t[6]||'') + ']</span></td>'+\
    '<td style="font-weight:900;">' + String(t[7]||'') + '</td>'+\
    '<td><span class="txt-harga-satuan">@' + formatRp(hargaSatuan) + '</span><span class="txt-harga-total">' + formatRp(hargaTotal) + '</span></td>'+\
    '<td>' + st + '</td>'+\
    '</tr>';\
  \});\
  \
  tbody.innerHTML = html;\
  hitungTotalBayar();\
\}\
