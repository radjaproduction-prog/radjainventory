\
function onPelunasanCheckChange(cb) \{\
  var lockedVendor = '';\
  document.querySelectorAll("#pelunasan-tbody input[type='checkbox']:checked").forEach(function(c) \{\
    if (!lockedVendor) lockedVendor = c.getAttribute('data-vendor') || '';\
  \});\
\
  document.querySelectorAll("#pelunasan-tbody input[type='checkbox']").forEach(function(c) \{\
    // LOGIKA BARU: Jika harganya kosong, LEWATI / ABAIKAN!\
    if (c.getAttribute('data-noharga') === 'true') return;\
\
    var v = c.getAttribute('data-vendor') || '';\
    var tr = c.closest('tr');\
    \
    if (lockedVendor && v !== lockedVendor) \{\
      c.disabled = true;\
      if (tr) tr.style.opacity = '0.3';\
    \} else \{\
      c.disabled = false;\
      if (tr) tr.style.opacity = '';\
    \}\
  \});\
\
  var allCb = document.getElementById('select-all-check');\
  if (allCb) \{\
    var checkedCount = document.querySelectorAll("#pelunasan-tbody input[type='checkbox']:checked").length;\
    if (checkedCount > 0) \{\
      allCb.disabled = false;\
      // Hitung total kotak vendor yg harganya TIDAK kosong\
      var totalVendorBoxes = document.querySelectorAll("#pelunasan-tbody input[type='checkbox'][data-vendor='"+lockedVendor+"']:not([data-noharga='true'])").length;\
      allCb.checked = (checkedCount === totalVendorBoxes && totalVendorBoxes > 0);\
    \} else \{\
      allCb.checked = false;\
      setTimeout(function() \{ allCb.disabled = true; \}, 50); // Obat untuk Safari Mac\
    \}\
  \}\
  \
  hitungTotalBayar();\
\}\
\
function selectAllPelunasan(cbAll) \{\
  var lockedVendor = '';\
  \
  // Jika ceklis master dilepas\
  if (!cbAll.checked) \{\
    document.querySelectorAll("#pelunasan-tbody input[type='checkbox']").forEach(function(cb) \{\
      // LOGIKA BARU: Jika harganya kosong, LEWATI!\
      if (cb.getAttribute('data-noharga') === 'true') return; \
      \
      cb.checked = false; \
      cb.disabled = false;\
      var tr = cb.closest('tr');\
      if (tr) tr.style.opacity = '';\
    \});\
    setTimeout(function() \{ cbAll.disabled = true; \}, 50); // Obat untuk Safari Mac\
    hitungTotalBayar();\
    return;\
  \}\
\
  // Jika ceklis master ditekan\
  var firstActive = document.querySelector("#pelunasan-tbody input[type='checkbox']:checked");\
  if (firstActive) lockedVendor = firstActive.getAttribute('data-vendor') || '';\
\
  document.querySelectorAll("#pelunasan-tbody input[type='checkbox']").forEach(function(cb) \{\
    // LOGIKA BARU: Jika harganya kosong, LEWATI!\
    if (cb.getAttribute('data-noharga') === 'true') return;\
\
    var v = cb.getAttribute('data-vendor') || '';\
    var tr = cb.closest('tr');\
\
    if (!lockedVendor || v === lockedVendor) \{\
      cb.checked = true; \
      cb.disabled = false;\
      if (tr) tr.style.opacity = '';\
    \} else \{\
      cb.checked = false; \
      cb.disabled = true;\
      if (tr) tr.style.opacity = '0.3';\
    \}\
  \});\
\
  hitungTotalBayar();\
\}\
\
function hitungTotalBayar() \{\
  var checkedIds = [];\
  document.querySelectorAll("#pelunasan-tbody input[type='checkbox']:checked").forEach(function(cb) \{\
    checkedIds.push(String(cb.value));\
  \});\
\
  var total = 0;\
  checkedIds.forEach(function(id) \{\
    var t = dataPelunasanGlobal.find(function(r)\{ return String(r[0]) === id; \});\
    if (!t) return;\
    var _hs = parseInt(t[9]||0);\
    var _ht = parseInt(t[10]||0);\
    var hs = _hs > 0 ? _hs : (cariHargaAwal(String(t[3]||''), String(t[4]||'')) || 0);\
    var ht = _ht > 0 ? _ht : (hs * parseInt(t[7]||0));\
    total += ht;\
  \});\
\
  // Update Angka Jumlah Ceklis di kiri\
  var countEl = document.getElementById("pelunasan-count");\
  if (countEl) countEl.innerText = checkedIds.length;\
\
  // Update Teks Nominal Total Bayar di kanan\
  var textEl = document.getElementById("pelunasan-total-text");\
  if (textEl) \{\
    textEl.innerText = checkedIds.length > 0 ? "TOTAL : " + formatRp(total) : "TOTAL BAYAR";\
  \}\
