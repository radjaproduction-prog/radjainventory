function simpanHargaProduk() \{\
var brand=document.getElementById("edit-brand").value, model=document.getElementById("edit-model").value, harga=document.getElementById("edit-harga").value;\
if (!brand||!model||!harga||harga<=0) \{ tampilkanPopup("Harap lengkapi Brand, Model, dan Harga!"); return; \}\
