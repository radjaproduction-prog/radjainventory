function getStokFiltered(field, filter) \{\
  var fieldIdx = \{brand:0, model:1, warna:2, ukuran:3\};\
  var fi = fieldIdx[field];\
  var result = [];\
  if (!dataHomeGlobal) return result;\
  \
  dataHomeGlobal.forEach(function(r) \{\
    var qty = parseInt(r[4]||0);\
    if (qty <= 0) return;\
    if (filter.brand  && r[0] !== filter.brand)  return;\
    if (filter.model  && r[1] !== filter.model)  return;\
    if (filter.warna  && r[2] !== filter.warna)  return;\
    var val = r[fi];\
    if (val && result.indexOf(val) === -1) result.push(val);\
  \});\
  \
  // Terapkan pengurutan kustom KHUSUS untuk ukuran\
  if (field === 'ukuran') \{\
    result.sort(customSortUkuran);\
  \} else \{\
    result.sort();\
  \}\
  return result;\
\}\
\
function getVendorUnik() \{\
var result = [];\
if (!dataRiwayatGlobal) return result;\
dataRiwayatGlobal.forEach(function(t) \{\
var v = String(t[2]||'');\
if (v && result.indexOf(v) === -1) result.push(v);\
\});\
result.sort();\
return result;\
\}\
