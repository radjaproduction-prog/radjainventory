function cariHargaAwal(brand, model) \{\
if (!appCache.harga || !brand || !model) return null;\
var found = null;\
appCache.harga.forEach(function(h) \{\
var b = Array.isArray(h) ? String(h[0]||'') : String(h.brand||'');\
var m = Array.isArray(h) ? String(h[1]||'') : String(h.model||'');\
var v = Array.isArray(h) ? parseInt(h[2]||0) : parseInt(h.harga||h.price||0);\
if (b===brand && m===model && v>0) found = v;\
\});\
return found;\
\}\
