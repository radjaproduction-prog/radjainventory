// === Simpan Stok ===\
async function simpanKeFirebase(data) \{\
  const q = query(collection(db,"stok"),\
    where("brand","==",data.brand), where("model","==",data.model),\
    where("warna","==",data.warna), where("ukuran","==",data.ukuran));\
  const snap = await getDocs(q);\
  \
  if (!snap.empty) \{\
    const ex = snap.docs[0];\
    await runTransaction(db, async (t) => \{\
      const ss = await t.get(ex.ref);\
      const currentQty = parseInt(ss.data().qty) || 0;\
      const newQty = currentQty + parseInt(data.jumlah);\
      \
      if (newQty < 0) \{\
        throw new Error("Sisa stok hanya " + currentQty + " pcs. Tidak bisa dikurangi " + Math.abs(data.jumlah) + " pcs!");\
      \}\
      t.update(ex.ref, \{ qty: newQty \});\
    \});\
  \} else \{\
    if (parseInt(data.jumlah) < 0) \{\
      throw new Error("Barang belum pernah ada di stok, tidak bisa dikurangi!");\
    \}\
    await addDoc(collection(db,"stok"), \{\
      brand: data.brand, model: data.model, warna: data.warna,\
      ukuran: data.ukuran, qty: parseInt(data.jumlah), waktu: serverTimestamp()\
    \});\
  \}\
  return \{ success: true \};\
\}\
\
// === Simpan Retur/Cacat (Tercatat di Riwayat) ===\
async function simpanReturKeFirebase(brand, model, warna, ukuran, qty) \{\
  const q = query(collection(db,"stok"),\
    where("brand","==",brand), where("model","==",model),\
    where("warna","==",warna), where("ukuran","==",ukuran));\
  const snap = await getDocs(q);\
  \
  if (snap.empty) throw new Error("Stok barang ini kosong/tidak ditemukan!");\
  \
  const stokDoc = snap.docs[0];\
  const now = new Date();\
  const pad = n => String(n).padStart(2,'0');\
  const idTrx = 'RETUR/' + now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate()) + '-' + String(Date.now()).slice(-5);\
  const newTrxRef = doc(collection(db, "transaksi"));\
  \
  await runTransaction(db, async (t) => \{\
    const ss = await t.get(stokDoc.ref);\
    const curQty = parseInt(ss.data().qty) || 0;\
    \
    if (qty > curQty) throw new Error("Gagal! Sisa stok di sistem hanya " + curQty + " pcs.");\
    \
    t.update(stokDoc.ref, \{ qty: curQty - qty \});\
    t.set(newTrxRef, \{ \
      idTrx: idTrx, \
      tanggal: serverTimestamp(), \
      vendor: "
\f1 \uc0\u9888 \u65039 
\f0  RETUR (CACAT)", \
      brand: brand, \
      model: model, \
      warna: warna, \
      ukuran: ukuran, \
      qty: qty, \
      status: "LUNAS", \
      hargaSatuan: 0, \
      hargaTotal: 0 \
    \});\
  \});\
  return \{ success: true \};\
\}\
\
// === Simpan Transaksi Keluar ===\
async function simpanTransaksiKeFirebase(vendor, brand, model, warna, ukuran, qty) \{\
  const q = query(collection(db,"stok"),\
    where("brand","==",brand), where("model","==",model),\
    where("warna","==",warna), where("ukuran","==",ukuran));\
  const snap = await getDocs(q);\
  if (snap.empty) throw new Error("Stok tidak ditemukan");\
  const stokDoc = snap.docs[0];\
  const now = new Date();\
  const pad = n => String(n).padStart(2,'0');\
  const idTrx = 'TRX/' + now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate()) + '-' + String(Date.now()).slice(-5);\
  const newTrxRef = doc(collection(db, "transaksi"));\
  await runTransaction(db, async (t) => \{\
    const ss = await t.get(stokDoc.ref);\
    const curQty = parseInt(ss.data().qty) || 0;\
    if (qty > curQty) throw new Error("Stok tidak mencukupi (" + curQty + " pcs)");\
    t.update(stokDoc.ref, \{ qty: curQty - qty \});\
    t.set(newTrxRef, \{ idTrx, tanggal: serverTimestamp(), vendor, brand, model, warna, ukuran, qty, status: "CREDIT", hargaSatuan: 0, hargaTotal: 0 \});\
  \});\
  return \{ success: true, message: "Transaksi " + idTrx + " berhasil disimpan!" \};\
\}\
\
// === Lunasi Transaksi ===\
async function lunasiTransaksiFirebase(ids) \{\
  const batch = writeBatch(db);\
  for (const idTrx of ids) \{\
    const q = query(collection(db,"transaksi"), where("idTrx","==",idTrx));\
    const snap = await getDocs(q);\
    if (!snap.empty) \{ batch.update(snap.docs[0].ref, \{ status: "LUNAS" \}); \}\
    else \{ try \{ batch.update(doc(db,"transaksi",idTrx), \{ status: "LUNAS" \}); \} catch(e) \{\} \}\
  \}\
  await batch.commit();\
  return \{ success: true, message: ids.length + " transaksi berhasil dilunasi!" \};\
\}\
